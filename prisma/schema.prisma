generator client {
  provider = "prisma-client-js"
}

// ── Database ────────────────────────────────────────────────────────────────
// PostgreSQL is the required production database.
//
// Local dev without PostgreSQL: see DEPLOYMENT.md "Local Development with SQLite"
// for a temporary fallback.
//
// Recommended managed Postgres: Railway, Neon, Supabase, or PlanetScale.
// Connection pooling: add ?pgbouncer=true&connection_limit=1 to DATABASE_URL
// when using Prisma with a serverless / edge deployment.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Required by Shopify app template
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  @@index([shop])
}

// Brand voice configuration per shop
model BrandVoice {
  id                 String   @id @default(cuid())
  shop               String   @unique
  storeName          String   @default("")
  brandTone          String   @default("professional")
  targetAudience     String   @default("")
  keyDifferentiators String   @default("")
  avoidPhrases       String   @default("")
  sampleContent      String   @default("")
  additionalNotes    String   @default("")
  targetKeywords         String   @default("") // comma-separated global SEO keywords
  language               String   @default("en") // ISO 639-1 output language code
  autopilotEnabled       Boolean  @default(false) // auto-generate on new product
  autopilotAutoPublish   Boolean  @default(false) // publish immediately during autopilot
  autopilotContentTypes  String   @default("description,metaTitle,metaDescription") // csv
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// AI-generated content per product per content type
model GeneratedContent {
  id               String   @id @default(cuid())
  shop             String
  productId        String
  productTitle     String   @default("")
  contentType      String   // "description" | "metaTitle" | "metaDescription" | "faq" | "altText"
  originalContent  String   @default("")
  generatedContent String   @default("")
  publishedContent String   @default("")
  status           String   @default("draft") // "draft" | "approved" | "published" | "rejected"
  version          Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([shop, productId, contentType])
  @@index([shop, productId])
  @@index([shop, status])
  @@index([shop, contentType, status])
  @@index([shop, updatedAt])
}

// Subscription plan per shop
model Plan {
  id               String    @id @default(cuid())
  shop             String    @unique
  planName         String    @default("free")   // "free" | "starter" | "growth" | "pro"
  status           String    @default("active") // "active" | "cancelled" | "frozen"
  monthlyLimit     Int       @default(10)       // max generations per calendar month
  shopifyChargeId  String?                      // Shopify AppSubscription GID
  currentPeriodEnd DateTime?                    // when the current billing period ends
  trialEndsAt      DateTime?
  renewsAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// Per-generation usage log — powers billing, analytics, and limit checks
model UsageRecord {
  id          String   @id @default(cuid())
  shop        String
  month       String   // "2026-05"  — YYYY-MM, makes monthly rollup trivial
  contentType String   // "description" | "metaTitle" | etc.
  productId   String?
  tokensUsed  Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([shop, month])
  @@index([shop, createdAt])
  @@index([shop, productId, createdAt])
}

// GDPR webhook audit log — required for Shopify App Store
model GDPRRequest {
  id          String   @id @default(cuid())
  shop        String
  requestType String   // "customer_data_request" | "customer_redact" | "shop_redact"
  payload     String   // raw JSON of the webhook payload
  processedAt DateTime @default(now())

  @@index([shop])
  @@index([requestType])
  @@index([processedAt])
}

// Saved content versions — written before each overwrite so merchants can roll back
model ContentVersion {
  id          String   @id @default(cuid())
  shop        String
  productId   String
  contentType String   // "description" | "metaTitle" | "metaDescription" | "faq"
  content     String
  version     Int      @default(1)
  createdAt   DateTime @default(now())

  @@index([shop, productId, contentType])
  @@index([shop, createdAt])
}

// Merchant-saved generation presets
model ContentTemplate {
  id                 String   @id @default(cuid())
  shop               String
  name               String
  contentLength      String   @default("standard") // "short"|"standard"|"detailed"
  contentTypes       String   @default("description,metaTitle,metaDescription") // csv
  keywords           String   @default("")
  customInstructions String   @default("")
  isDefault          Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@index([shop])
}

// Async bulk generation jobs
model GenerationJob {
  id                String    @id @default(cuid())
  shop              String
  status            String    @default("queued") // "queued" | "processing" | "complete" | "failed"
  totalProducts     Int       @default(0)
  completedProducts Int       @default(0)
  failedProducts    Int       @default(0)
  productIds        String    @default("[]")     // JSON array of Shopify Product GIDs
  contentTypes      String    @default("description") // comma-separated
  autoPublish       Boolean   @default(false)          // push to Shopify immediately after generation
  errorLog          String?   // JSON array of { productId, error }
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([shop, status])
  @@index([shop, createdAt])
  @@index([status, startedAt])
}

// Per-collection brand voice overrides — allows mixed-catalog merchants to use
// different tones for luxury vs technical vs budget product lines.
model CollectionVoice {
  id             String @id @default(cuid())
  shop           String
  collectionId   String
  brandTone      String @default("")
  targetAudience String @default("")
  keywords       String @default("")

  @@unique([shop, collectionId])
  @@index([shop])
}

// AI-generated blog posts — saved before/after publishing to Shopify
model BlogPost {
  id               String    @id @default(cuid())
  shop             String
  title            String    @default("")
  content          String    @default("")
  wordCount        Int       @default(0)
  topic            String    @default("")
  keywords         String    @default("")
  status           String    @default("draft")  // "draft" | "published"
  shopifyArticleId String?                       // Shopify article GID after publish
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([shop, status])
  @@index([shop, createdAt])
}

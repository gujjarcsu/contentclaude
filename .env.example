# ─── Shopify ─────────────────────────────────────────────────────────────────
SHOPIFY_API_KEY=                        # From Shopify Partner Dashboard → App → API credentials
SHOPIFY_API_SECRET=                     # From Shopify Partner Dashboard → App → API credentials
SHOPIFY_APP_URL=https://your-app.fly.dev # Your production deployment URL (must match shopify.app.toml)
SCOPES=write_products,write_metaobjects,write_metaobject_definitions,write_content

# ─── Database ────────────────────────────────────────────────────────────────
# Dev: SQLite (single-process, no setup required)
DATABASE_URL=file:dev.sqlite
# Prod: PostgreSQL via Neon (use the pooler hostname: ep-xxx-pooler.region.aws.neon.tech)
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1

# ─── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...            # From console.anthropic.com

# ─── Redis (optional in dev, REQUIRED in production for BullMQ + cache) ───────
REDIS_URL=redis://localhost:6379        # Or a managed Redis URL (Railway, Upstash, etc.)

# ─── External API ─────────────────────────────────────────────────────────────
# Used by POST /api/generate (Shopify Flow / external triggers).
# Auth mode: "hmac" (default, per-shop signature) or "token" (single shared secret).
CONTENTCLAUDE_AUTH_MODE=hmac
# Only required when CONTENTCLAUDE_AUTH_MODE=token.
# Generate a strong random secret: openssl rand -hex 32
CONTENTCLAUDE_API_TOKEN=

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=                             # Optional — from sentry.io project settings
LOG_LEVEL=info                          # debug | info | warn | error

# ─── Shopify optional ─────────────────────────────────────────────────────────
# SHOP_CUSTOM_DOMAIN=mystore.com        # Only needed if merchants use custom domains

# ─── Growth feature flags (all OFF by default — see app/utils/featureFlags.server.js)
# Enable per environment once a feature's UI is verified. Values: on / true / 1.
# FEATURE_MAGIC_MOMENT=on               # Phase 1 first-run auto-scan + live before→after
# FEATURE_RESULTS_DASHBOARD=on          # Phase 3 ROI/results dashboard
# FEATURE_CATEGORY_BENCHMARKING=on      # Phase 4 benchmarks (requires opt-in + privacy update)
# FEATURE_REVIEW_PROMPTS=on             # Phase 6 compliant review prompts (needs listing URL)

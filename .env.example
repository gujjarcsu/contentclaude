# ─── Shopify ─────────────────────────────────────────────────────────────────
SHOPIFY_API_KEY=                        # From Shopify Partner Dashboard → App → API credentials
SHOPIFY_API_SECRET=                     # From Shopify Partner Dashboard → App → API credentials
SHOPIFY_APP_URL=https://your-app.fly.dev # Your production deployment URL (must match shopify.app.toml)
SCOPES=write_products,write_metaobjects,write_metaobject_definitions

# ─── Database ────────────────────────────────────────────────────────────────
# Dev: SQLite (single-process, no setup required)
DATABASE_URL=file:dev.sqlite
# Prod: PostgreSQL (required for multi-tenant scale, see prisma/schema.prisma)
# DATABASE_URL=postgresql://user:pass@host:5432/contentpilot?pgbouncer=true&connection_limit=1

# ─── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...            # From console.anthropic.com

# ─── Redis (optional in dev, REQUIRED in production for BullMQ + cache) ───────
REDIS_URL=redis://localhost:6379        # Or a managed Redis URL (Railway, Upstash, etc.)

# ─── External API ─────────────────────────────────────────────────────────────
# Used by POST /api/generate (Shopify Flow / external triggers)
# Generate a strong random secret: openssl rand -hex 32
CONTENTPILOT_API_TOKEN=

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=                             # Optional — from sentry.io project settings
LOG_LEVEL=info                          # debug | info | warn | error

# ─── Shopify optional ─────────────────────────────────────────────────────────
# SHOP_CUSTOM_DOMAIN=mystore.com        # Only needed if merchants use custom domains
